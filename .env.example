# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-api-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Direct DB (injected by Supabase Vercel Integration)
# POSTGRES_URL_NON_POOLING=postgresql://postgres:password@host:5432/postgres

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Cron secret (for verifying cron job requests)
CRON_SECRET=your-cron-secret

# Demo mode (bypasses auth and external services)
# DEMO_MODE=true
# NEXT_PUBLIC_DEMO_MODE=true
