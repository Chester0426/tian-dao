# Supabase (database + auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-api-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (payment)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Anthropic (AI)
ANTHROPIC_API_KEY=sk-ant-...

# Auto-migration (set by Supabase Vercel Integration)
# POSTGRES_URL_NON_POOLING=postgresql://...

# Cron job secret (for Vercel Cron or external cron services)
CRON_SECRET=your-cron-secret

# App URL (used for Stripe redirect URLs; defaults to request origin if unset)
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# E2E testing (optional — defaults to localhost:3000)
# E2E_BASE_URL=http://localhost:3000

# Demo mode (set to "true" to run without real credentials)
# DEMO_MODE=true
# NEXT_PUBLIC_DEMO_MODE=true
