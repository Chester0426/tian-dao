# Supabase (database + auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-api-key

# Auto-migration (set by Supabase Vercel Integration — not needed for local dev)
# POSTGRES_URL_NON_POOLING=postgresql://...

# Supabase service role (server-only, for admin operations like passkey login)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# WebAuthn / Passkey (Touch ID login)
# WEBAUTHN_RP_ID=your-domain.vercel.app
# WEBAUTHN_ORIGIN=https://your-domain.vercel.app

# Demo mode (set to "true" to bypass Supabase calls — useful for local dev without a Supabase project)
# NEXT_PUBLIC_DEMO_MODE=true
# DEMO_MODE=true

# PostHog analytics
# NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_key
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# E2E testing (optional — defaults shown)
# E2E_PORT=3099
# E2E_BASE_URL=http://localhost:3099
